import React from 'react'
import Image from "next/image"
import Link from 'next/link'
import Login from "@/components/auth/login"
import SignUp from "@/components/auth/signup"
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs"


export default function AuthPage() {
  return (
    <div className="flex flex-col items-center justify-center min-h-screen bg-gradient-to-br from-gray-900 via-black to-gray-900">
        <Link href="/" className="mb-2">
            <Image
                src="/images/jobars-events.png"
                alt="Jobars Events"
                width={300}
                height={50}
            />
        </Link>
        <Tabs defaultValue="login" className="w-full items-center justify-center">
            <TabsList className='grid w-full max-w-md grid-cols-2 bg-gray-800 border border-gray-700'>
                <TabsTrigger value="login" className='data-[state=active]:bg-yellow-400 data-[state=active]:text-black text-gray-300'>Login</TabsTrigger>
                <TabsTrigger value="signup" className='data-[state=active]:bg-yellow-400 data-[state=active]:text-black text-gray-300'>Sign Up</TabsTrigger>
            </TabsList>
            <TabsContent value="login" className='w-full max-w-md click'>
                <Login />
            </TabsContent>
            <TabsContent value="signup" className='w-full max-w-md click'>
                <SignUp />
            </TabsContent>
        </Tabs>
    </div>
  )
}
